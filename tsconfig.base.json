{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@trainstack/types": ["packages/types/src"],
      "@trainstack/prompts": ["packages/prompts/src"],
      "@trainstack/ui/*": ["packages/ui/src/*"]
    }
  }
}
