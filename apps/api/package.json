    "@nestjs/platform-express": "^11.0.3",
    "@prisma/client": "^5.20.0",
    "@trainstack/prompts": "0.2.0",
    "@trainstack/types": "0.2.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.21.2",
